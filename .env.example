# --- PRODUCTION CONFIGURATION TEMPLATE ---
# Copy these keys into your Render/Cloud dashboard Environment Variables

# App Settings
NODE_ENV=production
PORT=10000
ALLOWED_ORIGINS=https://your-frontend-domain.com

# MongoDB (Use MongoDB Atlas)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGO_URI=

# Brevo (Email)
BREVO_API_KEY=
EMAIL_USER=shrayutech@gmail.com
ADMIN_EMAIL=admin@shrayu-technologies.com

# Redis (Optional: Leave empty to use Direct Fallback)
# Render Redis provides a URL like: rediss://default:password@host:port
REDIS_URL=

# Security
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY=
