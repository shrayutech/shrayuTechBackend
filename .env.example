PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/shrayu_db
NODE_ENV=development

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@shrayu-technologies.com

# Redis Configuration (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# reCAPTCHA Configuration (v3)
# To get keys, visit: https://www.google.com/recaptcha/admin
# For local development, leave as "yours-secret-key-here" to bypass verification
RECAPTCHA_SECRET_KEY=yours-secret-key-here
VITE_RECAPTCHA_SITE_KEY=your-site-key-here
